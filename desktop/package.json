{
  "name": "stellatrix-desktop",
  "productName": "Stellatrix",
  "version": "0.5.0",
  "description": "Stellatrix 本地一键部署桌面服务端 —— 在线模式连云端,本地模式起捆绑的 PostgreSQL + Python 后端",
  "private": true,
  "main": "src/main.js",
  "author": "Stellatrix",
  "license": "SEE LICENSE IN ../LICENSE",
  "scripts": {
    "start": "electron .",
    "bundle:backend": "bash scripts/bundle-backend.sh",
    "bundle:backend:win": "powershell -ExecutionPolicy Bypass -File scripts/bundle-backend.ps1",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "@electron/notarize": "^2.5.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "icu.stellatrix.desktop",
    "productName": "Stellatrix",
    "copyright": "Copyright © 2026 Stellatrix",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources-staged",
        "to": ".",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSAppTransportSecurity": { "NSAllowsLocalNetworking": true }
      }
    },
    "dmg": {
      "writeUpdateInfo": true
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "felixchaos",
        "repo": "rpg-roleplay-platform",
        "releaseType": "draft"
      }
    ],
    "afterSign": "build/notarize.js"
  }
}
