# ──────────────────────────────────────────────────────────────────
#  Expo managed workflow — Android RN client.
#
#  We use `expo prebuild` to regenerate the native android/ folder
#  from app.json + app config plugins, so the native scaffolding is
#  not tracked. Anyone who clones this can run:
#    npm install
#    npx expo prebuild --platform android
#    cd android && ./gradlew assembleRelease
#  to produce an APK identical to what was last released.
# ──────────────────────────────────────────────────────────────────

# Node / package manager
node_modules/
npm-debug.*
yarn-error.*
yarn-debug.*
.pnp.*

# Expo
.expo/
.expo-shared/
expo-env.d.ts
web-build/
dist/

# Native scaffolding — regenerated by `npx expo prebuild --platform android`
android/

# Local environment overrides (never commit; bake values via app.json or build flags)
.env
.env.*
!.env.example

# Build artifacts
*.apk
*.aab
*.ipa
*.app
*.jks
*.keystore
*.p12
*.mobileprovision

# IDE / editor noise
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# TypeScript build cache
*.tsbuildinfo
